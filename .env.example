# Серверные настройки
PORT=8080

# База данных PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5432/botflow
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=root

# Безопасность и JWT
JWT_SECRET=your_super_secret_key_minimum_32_characters_long

# Настройки почты Brevo SMTP
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@mail.kutman.me

# Интеграция с AI Сервисом (FastAPI)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_MOCK=true
